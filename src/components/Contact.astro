---
import { profile, socials } from "../data/profile";
import Icon from "./Icon.astro";

const FORMSPREE = "";
const social4 = socials.filter((s) => ["linkedin", "tiktok", "instagram", "youtube"].includes(s.icon));
---
<section id="contact" class="bg-apple-white">
  <div class="mx-auto w-full max-w-6xl px-6 py-10 md:py-14">
    <div class="rounded-3xl border border-apple-border bg-apple-gray p-6 md:p-10">
      <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Contact</p>
      <h2 class="mt-1 font-display text-4xl sm:text-5xl font-semibold text-apple-ink">Let's connect</h2>
      <p class="mt-3 max-w-xl text-apple-ink-2">
        Question about a video, a collaboration idea, or a role you'd like to discuss? Drop a note — I read everything.
      </p>

      <a href="/sponsors" class="mt-5 inline-flex items-center gap-2 rounded-full border border-flame-500/30 bg-flame-500/8 px-4 py-2 font-mono text-xs uppercase tracking-wider text-flame-600 hover:bg-flame-500/15 transition">
        <span class="size-1.5 rounded-full bg-flame-500"></span>
        Brand partnerships → media kit
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>

      <div class="mt-8 grid gap-10 md:grid-cols-[1.1fr_1fr]">
        <!-- Left: form -->
        <form id="contact-form" action={FORMSPREE || `mailto:${profile.email}`} method="POST" data-mailto={FORMSPREE ? "false" : "true"} data-email={profile.email} class="flex flex-col gap-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="font-mono text-[11px] uppercase tracking-wider text-apple-ink-2">Name</span>
              <input type="text" name="name" required autocomplete="name"
                     class="rounded-lg border border-apple-border-mid bg-white px-3 py-2.5 text-sm text-apple-ink outline-none placeholder:text-apple-ink-3 transition focus:border-flame-500 focus:ring-2 focus:ring-flame-500/20" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="font-mono text-[11px] uppercase tracking-wider text-apple-ink-2">Email</span>
              <input type="email" name="email" required autocomplete="email"
                     class="rounded-lg border border-apple-border-mid bg-white px-3 py-2.5 text-sm text-apple-ink outline-none placeholder:text-apple-ink-3 transition focus:border-flame-500 focus:ring-2 focus:ring-flame-500/20" />
            </label>
          </div>
          <label class="flex flex-col gap-1.5">
            <span class="font-mono text-[11px] uppercase tracking-wider text-apple-ink-2">Message</span>
            <textarea name="message" rows="5" required
                      class="resize-y rounded-lg border border-apple-border-mid bg-white px-3 py-2.5 text-sm text-apple-ink outline-none placeholder:text-apple-ink-3 transition focus:border-flame-500 focus:ring-2 focus:ring-flame-500/20"></textarea>
          </label>
          <button type="submit"
                  class="inline-flex w-max items-center gap-2 rounded-full bg-flame-500 px-5 py-2.5 font-display text-sm font-medium text-white hover:bg-flame-600 transition">
            Send message
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>

        <!-- Right: direct channels -->
        <div class="flex flex-col gap-5">
          <div class="space-y-3">
            <a href={`mailto:${profile.email}`} class="flex items-center gap-3 text-apple-ink hover:text-flame-500 transition">
              <Icon name="email" class="size-5" />
              <span class="font-mono text-sm">{profile.email}</span>
            </a>
            <a href={`tel:${profile.phone.replace(/\s/g, '')}`} class="flex items-center gap-3 text-apple-ink hover:text-flame-500 transition">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92Z"/></svg>
              <span class="font-mono text-sm">{profile.phone}</span>
            </a>
            <div class="flex items-center gap-3 text-apple-ink-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span class="font-mono text-sm">{profile.location}</span>
            </div>
          </div>

          <div class="pt-2">
            <p class="font-mono text-[11px] uppercase tracking-wider text-apple-ink-3 mb-3">Follow</p>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
              {social4.map((s) => (
                <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
                   class="flex items-center justify-center gap-2 rounded-xl border border-apple-border bg-white px-3 py-3 text-apple-ink-2 hover:text-flame-500 hover:border-apple-border-mid transition apple-card-shadow">
                  <Icon name={s.icon} class="size-5" />
                  <span class="font-mono text-xs">{s.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    if (!form || form.dataset.mailto !== 'true') return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const name = (fd.get('name') || '').toString().trim();
      const email = (fd.get('email') || '').toString().trim();
      const message = (fd.get('message') || '').toString().trim();
      const subject = encodeURIComponent(`Website contact — ${name || 'visitor'}`);
      const body = encodeURIComponent(`${message}\n\n—\nFrom: ${name} <${email}>`);
      window.location.href = `mailto:${form.dataset.email}?subject=${subject}&body=${body}`;
    });
  })();
</script>
