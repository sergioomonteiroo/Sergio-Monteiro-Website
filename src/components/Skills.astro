---
import { tools, expertise, languages } from "../data/profile";
---
<section id="skills" class="bg-apple-white">
  <div class="mx-auto w-full max-w-6xl px-6 py-14 md:py-20">
    <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Capabilities</p>
    <h2 class="mt-1 font-display text-4xl sm:text-5xl font-semibold text-apple-ink">What I bring to the bench</h2>

    <div class="mt-8 grid gap-5 md:grid-cols-[1.2fr_1.2fr_1fr]">
      <!-- Expertise -->
      <div class="rounded-2xl border border-apple-border bg-white p-5 apple-card-shadow">
        <h3 class="font-mono text-xs uppercase tracking-wider text-flame-500">Expertise</h3>
        <ul class="mt-3 flex flex-col gap-1.5">
          {expertise.map((item) => (
            <li class="flex items-start gap-2 text-sm text-apple-ink-2 leading-snug">
              <span class="mt-1.5 inline-block size-1 shrink-0 rounded-full bg-flame-500"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tools (chips) -->
      <div class="rounded-2xl border border-apple-border bg-white p-5 apple-card-shadow">
        <h3 class="font-mono text-xs uppercase tracking-wider text-flame-500">Tools</h3>
        <div class="mt-3 flex flex-wrap gap-2">
          {tools.map((t) => (
            <span class="rounded-md border border-apple-border bg-apple-gray px-2.5 py-1 font-mono text-xs text-apple-ink-2">{t}</span>
          ))}
        </div>
      </div>

      <!-- Languages (bars) -->
      <div class="rounded-2xl border border-apple-border bg-white p-5 apple-card-shadow">
        <h3 class="font-mono text-xs uppercase tracking-wider text-flame-500">Languages</h3>
        <ul class="mt-3 space-y-3">
          {languages.map((l) => (
            <li>
              <div class="flex items-baseline justify-between">
                <span class="font-display text-sm font-semibold text-apple-ink">{l.name}</span>
                <span class="font-mono text-[11px] text-apple-ink-3">{l.label}</span>
              </div>
              <div class="mt-1.5 flex gap-1">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={`h-1.5 flex-1 rounded-full ${i < l.level ? "bg-flame-500" : "bg-apple-border"}`}></span>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
