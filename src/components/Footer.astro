---
import { profile, socials } from "../data/profile";
import Icon from "./Icon.astro";
const year = new Date().getFullYear();
const nav = [
  { href: "#about", label: "About" },
  { href: "#media", label: "Media" },
  { href: "#education", label: "Education" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#skills", label: "Skills" },
  { href: "#awards", label: "Honors" },
  { href: "#contact", label: "Contact" },
];
const social4 = socials.filter((s) => ["linkedin", "tiktok", "instagram", "youtube"].includes(s.icon));
---
<footer class="bg-space-900">
  <div class="mx-auto w-full max-w-6xl px-6 py-10">
    <div class="grid gap-8 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <p class="font-display text-lg font-semibold text-ink-100">{profile.name}</p>
        <p class="mt-1 font-mono text-xs text-ink-400">{profile.role}</p>
        <p class="font-mono text-xs text-ink-500">{profile.subtitle}</p>
      </div>

      <div>
        <p class="font-mono text-[11px] uppercase tracking-wider text-ink-500 mb-3">Explore</p>
        <ul class="grid grid-cols-2 gap-y-1.5 gap-x-4 font-mono text-xs text-ink-400">
          {nav.map((n) => (
            <li><a href={n.href} class="hover:text-ink-100 transition">{n.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-mono text-[11px] uppercase tracking-wider text-ink-500 mb-3">Follow</p>
        <div class="flex flex-wrap gap-2">
          {social4.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
               class="flex size-10 items-center justify-center rounded-lg border border-white/10 bg-space-800 text-ink-400 hover:text-ink-100 hover:border-white/20 transition">
              <Icon name={s.icon} class="size-4" />
            </a>
          ))}
        </div>
        <a href={`mailto:${profile.email}`} class="mt-3 inline-block font-mono text-xs text-ink-400 hover:text-ink-100 transition">{profile.email}</a>
      </div>
    </div>

    <div class="mt-8 flex flex-col items-start justify-between gap-2 border-t border-white/10 pt-6 font-mono text-[11px] text-ink-500 md:flex-row md:items-center">
      <div>© {year} {profile.name}. All rights reserved.</div>
      <div>{profile.location} · Built with Astro &amp; Tailwind</div>
    </div>
  </div>
</footer>
