---
import Icon from "./Icon.astro";
import type { SocialLink } from "../data/links";
interface Props { link: SocialLink; }
const { link } = Astro.props;
const rel = link.external ? "noopener noreferrer" : undefined;
const target = link.external ? "_blank" : undefined;
---
<a
  href={link.href}
  rel={rel}
  target={target}
  class="group relative flex items-center gap-4 rounded-xl border border-white/10 bg-space-800/60 p-4 backdrop-blur-sm transition hover:border-flame-500/60 hover:bg-space-700/60 hover:-translate-y-0.5 hover:shadow-[0_8px_30px_-10px_rgba(255,107,53,0.35)]"
>
  <span class="flex size-11 shrink-0 items-center justify-center rounded-lg bg-space-900 text-ink-100 group-hover:text-flame-500 transition">
    <Icon name={link.icon} class="size-5" />
  </span>
  <span class="flex flex-col min-w-0">
    <span class="font-display text-base font-medium text-ink-100">{link.label}</span>
    {link.handle && <span class="font-mono text-xs text-ink-500 truncate">{link.handle}</span>}
  </span>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto size-4 text-ink-500 transition group-hover:text-flame-500 group-hover:translate-x-0.5" aria-hidden="true">
    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
  </svg>
</a>
