---
import { work } from "../data/profile";
---
<section id="experience" class="mx-auto w-full max-w-6xl px-6 py-14 md:py-20">
  <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Experience</p>
  <h2 class="mt-1 font-display text-4xl sm:text-5xl font-semibold text-apple-ink">Where I've worked</h2>

  <ol class="relative mt-10 space-y-6 border-l border-apple-border pl-0 pb-2">
    {work.map((w) => (
      <li class="relative pl-10">
        <span class="absolute left-0 top-5 flex size-9 -translate-x-1/2 items-center justify-center rounded-full border border-apple-border bg-white font-mono text-[11px] font-bold text-flame-500 ring-4 ring-apple-gray apple-card-shadow">
          {w.initials}
        </span>
        <div class="rounded-2xl border border-apple-border bg-white p-5 apple-card-shadow transition hover:-translate-y-0.5 hover:border-apple-border-mid">
          <div class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="font-display text-lg font-semibold text-apple-ink">{w.role}</h3>
              {w.current && (
                <span class="inline-flex items-center gap-1 rounded-full border border-flame-500/30 bg-flame-500/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-flame-600">
                  <span class="size-1.5 rounded-full bg-flame-500 animate-pulse"></span>
                  Current
                </span>
              )}
            </div>
            <p class="font-mono text-xs text-flame-500 whitespace-nowrap">{w.period}</p>
          </div>
          <p class="font-mono text-sm text-apple-ink-2 mt-1">{w.company} <span class="text-apple-ink-3">· {w.location}</span></p>
          <ul class="mt-3 space-y-1.5">
            {w.bullets.map((b) => (
              <li class="flex items-start gap-2 text-sm text-apple-ink-2 leading-snug">
                <span class="mt-1.5 inline-block size-1 shrink-0 rounded-full bg-flame-500"></span>
                <span set:html={b}></span>
              </li>
            ))}
          </ul>
        </div>
      </li>
    ))}
  </ol>
</section>
