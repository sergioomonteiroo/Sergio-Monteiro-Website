---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/profile";

const channels = [
  { platform: "TikTok", handle: "@sergioomonteiroo0", href: "https://www.tiktok.com/@sergioomonteiroo0", note: "Short-form aerospace explainers" },
  { platform: "YouTube", handle: "@SergioMonteiroAero", href: "https://www.youtube.com/@SergioMonteiroAero", note: "Long-form & shorts" },
  { platform: "Instagram", handle: "@sergioomonteiroo", href: "https://www.instagram.com/sergioomonteiroo/", note: "Behind-the-scenes" },
  { platform: "LinkedIn", handle: "in/sergiomonteirog", href: "https://www.linkedin.com/in/sergiomonteirog/", note: "Industry & engineering audience" },
];

const audience = [
  { label: "Primary audience", value: "Aerospace engineers & engineering students" },
  { label: "Demographics", value: "18–34, predominantly male, STEM-focused" },
  { label: "Geographies", value: "US, Spain, UK, Germany, Brazil" },
  { label: "Engagement", value: "High-intent, niche, technical commentary" },
];

const packages = [
  {
    name: "Integrated Mention",
    price: "€300 – €500",
    desc: "15-second brand integration inside a 60-second TikTok or YouTube Short.",
    deliverables: ["1 TikTok with native mention", "Cross-post to YouTube Shorts", "Usage rights: 30 days"],
  },
  {
    name: "Dedicated Post",
    price: "€600 – €1,000",
    desc: "A full short-form video built around the product or service.",
    deliverables: ["1 dedicated TikTok (60–90s)", "Cross-post to YouTube Shorts", "Story teaser (IG)", "Usage rights: 60 days"],
    highlight: true,
  },
  {
    name: "Bundle",
    price: "€1,200 – €1,800",
    desc: "Multi-platform campaign with extended reach and creative depth.",
    deliverables: ["1 dedicated TikTok", "1 YouTube Short or long-form segment", "1 Instagram Story set", "1 LinkedIn post", "Usage rights: 90 days"],
  },
];

const whyMe = [
  "Aerospace Engineer at Airbus Defence & Space — Eurofighter avionics",
  "MS Aerospace Engineering, Embry-Riddle (GPA 9.75/10)",
  "GNC specialist with real-world flight programs",
  "Trilingual (EN / ES / PT) — global audience reach",
];
---
<Base title={`Sponsorships — ${profile.name}`} description={`Partner with ${profile.name}, aerospace engineer & creator. Media kit, audience, and rates.`}>
  <Nav />

  <main class="bg-apple-gray">
    <!-- Hero -->
    <section class="mx-auto w-full max-w-5xl px-6 pt-28 pb-10 md:pt-32 md:pb-14">
      <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Media Kit · Sponsorships</p>
      <h1 class="mt-2 font-display text-4xl sm:text-5xl md:text-6xl font-semibold text-apple-ink leading-[1.04]" style="letter-spacing: -0.03em;">
        Partner with an aerospace engineer your audience already trusts.
      </h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg text-apple-ink-2 leading-relaxed">
        I'm Sergio — Avionics Systems Engineer on the Eurofighter at Airbus by day, aerospace educator by night. My audience is high-intent: engineers, students, and aerospace professionals who buy serious tools.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={`mailto:${profile.email}?subject=Sponsorship%20enquiry`} class="inline-flex items-center gap-2 rounded-full bg-flame-500 px-5 py-2.5 font-display text-sm font-medium text-white hover:bg-flame-600 transition">
          Start a conversation
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/media-kit.pdf" class="inline-flex items-center gap-2 rounded-full border border-apple-border-mid bg-white px-5 py-2.5 font-display text-sm font-medium text-apple-ink hover:bg-apple-gray transition apple-card-shadow">
          Download media kit (PDF)
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
      </div>
    </section>

    <!-- Channels -->
    <section class="mx-auto w-full max-w-5xl px-6 py-10 md:py-14">
      <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Channels</p>
      <h2 class="mt-1 font-display text-3xl sm:text-4xl font-semibold text-apple-ink">Where the audience lives</h2>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {channels.map((c) => (
          <a href={c.href} target="_blank" rel="noopener noreferrer" class="group rounded-2xl border border-apple-border bg-white p-5 apple-card-shadow transition hover:-translate-y-0.5 hover:border-apple-border-mid">
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-display text-lg font-semibold text-apple-ink">{c.platform}</h3>
              <span class="font-mono text-xs text-flame-500">{c.handle}</span>
            </div>
            <p class="mt-2 text-sm text-apple-ink-2">{c.note}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Audience -->
    <section class="mx-auto w-full max-w-5xl px-6 py-10 md:py-14">
      <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Audience</p>
      <h2 class="mt-1 font-display text-3xl sm:text-4xl font-semibold text-apple-ink">Who you'll reach</h2>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {audience.map((a) => (
          <div class="rounded-xl border border-apple-border bg-white p-5 apple-card-shadow">
            <p class="font-mono text-[11px] uppercase tracking-wider text-apple-ink-3">{a.label}</p>
            <p class="mt-1.5 font-display text-base font-medium text-apple-ink">{a.value}</p>
          </div>
        ))}
      </div>

      <p class="mt-4 text-xs font-mono text-apple-ink-3">Live follower counts and demographics are included in the downloadable PDF media kit.</p>
    </section>

    <!-- Packages -->
    <section class="mx-auto w-full max-w-5xl px-6 py-10 md:py-14">
      <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Packages</p>
      <h2 class="mt-1 font-display text-3xl sm:text-4xl font-semibold text-apple-ink">How we can work together</h2>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {packages.map((p) => (
          <article class:list={["rounded-2xl border bg-white p-6 apple-card-shadow transition hover:-translate-y-0.5", p.highlight ? "border-flame-500/40 ring-2 ring-flame-500/20" : "border-apple-border hover:border-apple-border-mid"]}>
            {p.highlight && <span class="inline-block rounded-full bg-flame-500/10 border border-flame-500/30 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-flame-600 mb-3">Most popular</span>}
            <h3 class="font-display text-xl font-semibold text-apple-ink">{p.name}</h3>
            <p class="mt-2 font-mono text-sm text-flame-500">{p.price}</p>
            <p class="mt-3 text-sm text-apple-ink-2 leading-relaxed">{p.desc}</p>
            <ul class="mt-4 space-y-1.5 border-t border-apple-border pt-4">
              {p.deliverables.map((d) => (
                <li class="flex items-start gap-2 text-sm text-apple-ink-2">
                  <span class="mt-1.5 inline-block size-1 shrink-0 rounded-full bg-flame-500"></span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <p class="mt-6 text-xs font-mono text-apple-ink-3">All packages include creative direction, native scripting, and on-brand integration. Final rates depend on scope, exclusivity, and usage rights.</p>
    </section>

    <!-- Why me -->
    <section class="mx-auto w-full max-w-5xl px-6 py-10 md:py-14">
      <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Why me</p>
      <h2 class="mt-1 font-display text-3xl sm:text-4xl font-semibold text-apple-ink">A creator who's actually in the cockpit</h2>

      <ul class="mt-8 grid gap-3 md:grid-cols-2">
        {whyMe.map((w) => (
          <li class="flex items-start gap-3 rounded-xl border border-apple-border bg-white p-4 apple-card-shadow">
            <span class="mt-1 inline-flex size-5 shrink-0 items-center justify-center rounded-full bg-flame-500/10 border border-flame-500/30 text-flame-500">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-sm text-apple-ink leading-snug">{w}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- CTA -->
    <section class="mx-auto w-full max-w-5xl px-6 py-14 md:py-20">
      <div class="rounded-3xl border border-apple-border bg-white p-8 md:p-12 apple-card-shadow text-center">
        <p class="font-mono text-xs uppercase tracking-wider text-flame-500">Ready to talk</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl font-semibold text-apple-ink">Let's build something your audience will remember.</h2>
        <p class="mt-4 max-w-xl mx-auto text-base text-apple-ink-2">
          Tell me about your product and the goals — I'll come back within 48 hours with a creative angle and timeline.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a href={`mailto:${profile.email}?subject=Sponsorship%20enquiry`} class="inline-flex items-center gap-2 rounded-full bg-flame-500 px-6 py-3 font-display text-sm font-medium text-white hover:bg-flame-600 transition">
            {profile.email}
          </a>
          <a href="/" class="inline-flex items-center gap-2 rounded-full border border-apple-border-mid bg-white px-6 py-3 font-display text-sm font-medium text-apple-ink hover:bg-apple-gray transition apple-card-shadow">
            Back to portfolio
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
